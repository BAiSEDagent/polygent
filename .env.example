# Cogent Environment Configuration

# Server
PORT=3000
NODE_ENV=development
ADMIN_API_KEY=change-me-to-a-secure-random-string

# Polymarket CLOB
POLYMARKET_CLOB_URL=https://clob.polymarket.com
BUILDER_ID=your-builder-id
BUILDER_API_KEY=your-builder-api-key

# Polymarket Data APIs
GAMMA_API_URL=https://gamma-api.polymarket.com
DATA_API_URL=https://data-api.polymarket.com
SPORTS_API_URL=https://sports-api.polymarket.com
SPORTS_WS_URL=wss://sports-api.polymarket.com/ws

# Operator Wallet (signs proxy wallet deployments)
OPERATOR_PRIVATE_KEY=0x_your_private_key_here

# Risk Defaults
DEFAULT_MAX_POSITION_PCT=0.20
DEFAULT_MAX_DRAWDOWN_PCT=0.30
DEFAULT_MAX_ORDER_SIZE=10000
DEFAULT_DAILY_LOSS_LIMIT_PCT=0.15

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
